# ── Flutterwave ──────────────────────────────────────────────────────────────
# Get these from your Flutterwave dashboard → Settings → API Keys
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# Set this in Flutterwave dashboard → Settings → Webhooks → Secret Hash
# Any random string you choose — Flutterwave sends it back in the verif-hash header
FLW_WEBHOOK_SECRET=your_secret_hash_here

# ── SMS via Termii (termii.com) ───────────────────────────────────────────────
# Leave blank to skip SMS and only log to console
TERMII_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── App URL (used to build redirect links) ───────────────────────────────────
# For local dev with ngrok: https://your-id.ngrok.io
# For production: https://yourdomain.com
APP_URL=http://localhost:3000
